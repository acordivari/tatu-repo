# Copy to api/.env and fill in. Never commit api/.env (it is gitignored).

# Apify API token — required for live scraping (rake instagram:scrape).
# Get it at https://console.apify.com/account/integrations
APIFY_TOKEN=

# Optional: override the Instagram scraper actor (defaults to apify~instagram-scraper).
# APIFY_INSTAGRAM_ACTOR=apify~instagram-scraper

# Optional: comma-separated allowed origins for the SPA (CORS).
# FRONTEND_ORIGINS=http://localhost:5173
