# Copy to api/.env and fill in. Never commit api/.env (it is gitignored).

# Apify API token — required for live scraping (rake instagram:scrape).
# Get it at https://console.apify.com/account/integrations
APIFY_TOKEN=

# Anthropic API key — required for LLM location extraction from bios
# (rake instagram:extract_locations). Get it at https://console.claude.com
ANTHROPIC_API_KEY=

# Google Maps Platform key with the Places API (New) enabled — required to
# resolve shops to verified businesses (rake instagram:resolve_shops).
# Create at https://console.cloud.google.com (APIs & Services → Credentials).
GOOGLE_MAPS_API_KEY=

# Cloudflare R2 (S3-compatible) — production Active Storage for images, and the
# one-time image migration (rake storage:migrate_to_r2). Create an R2 API token
# at R2 → Manage R2 API Tokens (see DEPLOY.md). The endpoint is the bucket's
# "S3 API" URL: https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# Optional: override the Instagram scraper actor (defaults to apify~instagram-scraper).
# APIFY_INSTAGRAM_ACTOR=apify~instagram-scraper

# Optional: comma-separated allowed origins for the SPA (CORS).
# FRONTEND_ORIGINS=http://localhost:5173

# Render External Database URL (Render → tatu-db → Connect), with ?sslmode=require.
# Lets `bin/add-artists` write new artists to production from your machine, so the
# pipeline API keys above never have to be put on the server. Leave blank if you
# only run the pipeline against your local dev database.
PROD_DATABASE_URL=
